# ─────────────────────────────────────────
# Database (Turso)
# ─────────────────────────────────────────
DATABASE_URL=libsql://your-database-name.turso.io
DATABASE_AUTH_TOKEN=your-auth-token

# ─────────────────────────────────────────
# App
# ─────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
API_SECRET_KEY=your-api-secret-key
CRON_SECRET=your-cron-secret

# ─────────────────────────────────────────
# Gmail (이메일 수집 및 발송)
# scripts/get-gmail-refresh-token.ts 로 발급
# ─────────────────────────────────────────
GMAIL_USER=your-email@gmail.com
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REFRESH_TOKEN=your-google-refresh-token

# ─────────────────────────────────────────
# LLM — Gemini (기본 폴백)
# ─────────────────────────────────────────
GOOGLE_GEMINI_API_KEY=your-gemini-api-key
GEMINI_CLASSIFY_MODEL=gemini-2.5-flash
GEMINI_REPLY_MODEL=gemini-2.5-flash

# ─────────────────────────────────────────
# LLM — Flock.io (해커톤 필수, 우선 사용)
# https://flock.io 에서 발급
# ─────────────────────────────────────────
FLOCK_API_KEY=your-flock-api-key
FLOCK_BASE_URL=https://api.flock.io/v1
FLOCK_MODEL=flock-web3-agent

# ─────────────────────────────────────────
# Coinbase AgentKit (NFT 민팅)
# https://portal.cdp.coinbase.com 에서 발급
# ─────────────────────────────────────────
CDP_API_KEY_ID=your-cdp-api-key-id
CDP_API_KEY_SECRET=your-cdp-api-key-secret
CDP_WALLET_SECRET=your-cdp-wallet-secret
AGENT_WALLET_ADDRESS=0x-your-agent-wallet-address
BASE_NETWORK=base-sepolia

# ─────────────────────────────────────────
# NFT Contract (Base Sepolia)
# Remix IDE로 contracts/ReplyNFT.sol 배포 후 입력
# ─────────────────────────────────────────
NFT_CONTRACT_ADDRESS=0x-your-nft-contract-address

# ─────────────────────────────────────────
# x402 자율 결제 (선택)
# ─────────────────────────────────────────
X402_ENABLED=false

# ─────────────────────────────────────────
# Virtuals GAME (멀티 에이전트)
# https://console.game.virtuals.io 에서 발급
# ─────────────────────────────────────────
GAME_API_KEY=your-game-api-key

# ─────────────────────────────────────────
# Virtuals ACP (에이전트 상거래, 선택)
# 설정 방법:
#   cd acp-cli && IS_TESTNET=true npx tsx src/index.ts configure
#   IS_TESTNET=true npx tsx src/index.ts agent create
#   IS_TESTNET=true npx tsx src/index.ts agent register-erc8004 --chain-id 84532
#   IS_TESTNET=true npx tsx src/index.ts agent whoami  → AGENT_WALLET_ADDRESS 확인
# ─────────────────────────────────────────
ACP_ENABLED=false
IS_TESTNET=true
AGENT_WALLET_ADDRESS=0x-your-smart-contract-wallet-from-acp-cli  # acp agent whoami 결과
ACP_REPLY_PROVIDER_ADDRESS=0x-reply-worker-agent-address
ACP_NFT_PROVIDER_ADDRESS=0x-nft-worker-agent-address

# ─────────────────────────────────────────
# 이메일 발송 설정
# ─────────────────────────────────────────
REPLY_DELAY_MIN=10
REPLY_DELAY_MAX=30
EMAIL_DRY_RUN=false
FOLLOWUP_ENABLED=true
FOLLOWUP_MAX_COUNT=4

# ─────────────────────────────────────────
# 답장 생성 설정
# ─────────────────────────────────────────
USE_TWO_STEP_REPLY=true

# ─────────────────────────────────────────
# 데모 모드 (해커톤 당일 전용)
# true 시 지연 발송 0~30초로 단축
# ─────────────────────────────────────────
DEMO_MODE=false

# ─────────────────────────────────────────
# Nansen (온체인 지갑 프로파일링)
# https://app.nansen.ai 에서 발급
# ─────────────────────────────────────────
NANSEN_API_KEY=your-nansen-api-key
NANSEN_BASE_URL=https://api.nansen.ai/v1